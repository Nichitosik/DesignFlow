# Database
DATABASE_URL=postgresql://user:password@localhost:5432/eventflow

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production

# Google Maps (get key from https://console.cloud.google.com)
# Enable: Maps JavaScript API, Directions API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# AI Recommendations (Groq API - https://console.groq.com)
OPENAI_API_KEY=your_groq_api_key_here

# Server
PORT=3000
